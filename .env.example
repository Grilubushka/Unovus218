TELEGRAM_BOT_TOKEN=replace_with_botfather_token
MINIAPP_URL=https://your-domain.ru/
STATE_FILE=bot_state.json
DATABASE_PATH=data/bot.sqlite3

# Django admin API bridge. If ADMIN_API_BASE_URL is empty, the bot keeps legacy behavior only.
ADMIN_API_BASE_URL=https://your-django-domain.ru
ADMIN_API_TOKEN=replace_with_shared_admin_api_token
ADMIN_API_TIMEOUT=300

# LLM-адаптация онбординга. Токен доступа не коммитим: добавь реальный ключ в локальный .env.
LLM_ONBOARDING_ENABLED=true
LLM_AGENT_BASE_URL=https://agent.timeweb.cloud/api/v1/cloud-ai/agents/2dad3aa1-b649-4dbe-ac57-a079192e0abf/v1
LLM_AGENT_ACCESS_ID=2dad3aa1-b649-4dbe-ac57-a079192e0abf
LLM_AGENT_TOKEN=replace_with_timeweb_agent_token
LLM_AGENT_MODEL=gpt-4.1
LLM_AGENT_TIMEOUT=0
LLM_AGENT_MAX_TOKENS=500
LLM_AGENT_PROGRESS_INTERVAL=2
